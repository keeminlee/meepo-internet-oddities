[Unit]
Description=Meepo Internet Oddities (MIO Web)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=meepo
Group=meepo
WorkingDirectory=/home/meepo/mio
EnvironmentFile=/etc/mio/mio-web.env
ExecStart=/home/meepo/mio/node_modules/.bin/next start -p 3001
Restart=always
RestartSec=5
TimeoutStopSec=20
KillSignal=SIGTERM
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
