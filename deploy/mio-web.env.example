# Copy to /etc/mio/mio-web.env and fill values.
NODE_ENV=production

# ─── Persistence ────────────────────────────────────────
# Absolute path to the SQLite database file (outside the repo checkout).
MIO_DB_PATH=/var/lib/mio/mio.db

# Absolute path to the durable uploads directory (outside the repo checkout).
MIO_UPLOAD_DIR=/var/lib/mio/uploads

# ─── GitHub OAuth ───────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://meepo.online/api/auth/github/callback
FRONTEND_URL=https://meepo.online

# Server-side HMAC secret for signing the OAuth state cookie.
SESSION_SECRET=generate-a-random-string-here

# ─── Admin ──────────────────────────────────────────────
# Comma-separated GitHub emails allowed to approve/reject submissions.
MEEPO_WRITERS=
