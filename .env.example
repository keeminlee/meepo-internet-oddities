# Meepo Internet Oddities — environment configuration
#
# Copy to `.env.local` (gitignored) and fill in real values.

# ─── Persistence ────────────────────────────────────────
# Absolute path to the SQLite database file. Put this OUTSIDE the repo
# checkout in production so a deploy never touches live data.
# Local dev default (when unset): <repo>/data/mio.db (gitignored).
MIO_DB_PATH=/var/lib/mio/mio.db

# Absolute path to the durable uploads directory (screenshots, future avatars).
# MUST be outside the repo checkout in production so a deploy never wipes files.
# Local dev default (when unset): <repo>/data/uploads (gitignored).
MIO_UPLOAD_DIR=/var/lib/mio/uploads

# Path to the seed JSON file for first-boot bootstrap (legacy db.json shape).
# Default: <repo>/_legacy/server/db.json
# MIO_SEED_PATH=/var/lib/mio/seed.json

# ─── GitHub OAuth ───────────────────────────────────────
# Create a GitHub OAuth App at https://github.com/settings/developers.
# Set the callback URL to match GITHUB_CALLBACK_URL below.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Where GitHub should redirect after authorize. Must match the GitHub app config.
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Public URL of the app (used for post-auth redirects).
FRONTEND_URL=http://localhost:3000

# Server-side HMAC secret for signing the OAuth state cookie.
# Rotate to invalidate all pending OAuth handshakes.
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Review / Admin ─────────────────────────────────────
# Comma-separated GitHub account emails allowed to approve/reject submissions
# and use the reserved "Meepo" tag. Empty list = no writers.
MEEPO_WRITERS=
