# Meepo Internet Oddities — Environment Variables
# Copy to .env and adjust for your environment.

# Server port (default: 3001)
PORT=3001

# Bind address (default: 0.0.0.0 in production, localhost otherwise)
HOST=0.0.0.0

# Set to "production" to enable static file serving from dist/
NODE_ENV=production

# ── GitHub OAuth ─────────────────────────────────────────
# Create a GitHub OAuth App at https://github.com/settings/developers
# Set the callback URL to: https://meepo.online/api/auth/github/callback (prod)
#   or http://localhost:3001/api/auth/github/callback (dev)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session secret — used conceptually for session token namespace; change in production
SESSION_SECRET=change-me-in-production

# Frontend URL for OAuth redirects and CORS (must match Vite dev port: 8080)
FRONTEND_URL=http://localhost:8080

# OAuth callback URL (must match GitHub OAuth App settings)
CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Comma-separated list of email addresses for MEEPO_WRITERS (reviewers)
MEEPO_WRITERS=
